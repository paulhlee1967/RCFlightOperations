# RC Flight Operations — root .htaccess
#
# Apache / LiteSpeed / cPanel: this file is used automatically.
# Nginx: .htaccess is ignored — enforce the same canonical-host redirect in your
# vhost (see DEPLOY.md). The PHP-level guard in includes/canonical_host.php also
# covers the app on any server, so this file is an edge-level optimisation that
# also catches static assets.

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Canonical host: redirect www.<host> to the apex <host> so session cookies
    # and absolute URLs stay on one hostname. Preserves scheme, path, and query.
    # If you standardise on www instead, replace this block with the inverse rule.
    RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
    RewriteRule ^ %{REQUEST_SCHEME}://%1%{REQUEST_URI} [R=301,L]

    # Public membership application (rcflightops.pvmac.com/apply)
    RewriteRule ^apply/?$ apply.php [L,QSA]
    RewriteRule ^apply/confirm/?$ apply_confirm.php [L,QSA]
</IfModule>

# Disable directory listing.
Options -Indexes

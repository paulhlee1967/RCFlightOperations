# Local config (DB credentials) – never commit
/config.php

# Composer (root vendor/ not committed; lock is committed for reproducible installs)
/vendor/
composer.phar

# Uploaded files (logos, favicons, member photos)
uploads/*
!uploads/.htaccess
uploads/.ama_verify_cache.json

# Legacy member photo directory (removed in v1.5 — use uploads/ and scripts/import_member_photos.php)
pics/

# OS and editor
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/

# Database dump (used when migrating test data to cPanel – do not commit)
export_for_cpanel.sql

# Logs and temp (keep logs/.htaccess and logs/.gitignore tracked)
logs/*
!logs/.htaccess
!logs/.gitignore
*.log
.phpunit.cache/
.env
.env.local
.env.*.local

# Deployment / host upload (do not commit)
Archive.zip
